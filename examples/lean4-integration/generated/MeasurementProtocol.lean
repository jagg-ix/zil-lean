namespace Zil.Generated.MeasurementProtocol

/-! ## MeasurementRun -/

/- MeasurementRunState mapping (source -> Lean constructor)
- aborted -> aborted
- acquiring -> acquiring
- analyzing -> analyzing
- archived -> archived
- calibrating -> calibrating
- idle -> idle
-/
inductive MeasurementRunState where
  | aborted
  | acquiring
  | analyzing
  | archived
  | calibrating
  | idle
  deriving DecidableEq, Repr

/- MeasurementRunEvent mapping (source -> Lean constructor)
- acquisition_done -> acquisitionDone
- begin_calibration -> beginCalibration
- calibration_fail -> calibrationFail
- calibration_ok -> calibrationOk
- detector_fault -> detectorFault
- results_archived -> resultsArchived
-/
inductive MeasurementRunEvent where
  | acquisitionDone
  | beginCalibration
  | calibrationFail
  | calibrationOk
  | detectorFault
  | resultsArchived
  deriving DecidableEq, Repr

def initialMeasurementRunState : MeasurementRunState := .idle

def stepMeasurementRun (s : MeasurementRunState) (e : MeasurementRunEvent) : MeasurementRunState :=
  match s, e with
  | .acquiring, .acquisitionDone => .analyzing
  | .acquiring, .detectorFault => .aborted
  | .analyzing, .resultsArchived => .archived
  | .calibrating, .calibrationFail => .aborted
  | .calibrating, .calibrationOk => .acquiring
  | .idle, .beginCalibration => .calibrating
  | _, _ => s

def MeasurementRunCanonicalTrace : List MeasurementRunEvent := [.beginCalibration, .calibrationFail]


