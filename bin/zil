#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ZIL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

native_help() {
  cat <<'EOF'
Usage:
  bin/zil compile <input.zc> [output.lean|-] [namespace]
  bin/zil expand <input.zc> [output.zc|-]
  bin/zil macro-compile <input.zc> [--output FILE|-] [--namespace NAME] [--lib DIR]
  bin/zil macro-expand <input.zc> [--output FILE|-] [--lib DIR]
  bin/zil macro-parity <input.zc> [--output FILE|-] [--lib DIR]
  bin/zil conformance <input.zc> [output.zilc|-]
  bin/zil conformance-suite [--root DIR]... [--output FILE] [--lib DIR]
  bin/zil library [--root DIR]... [--out DIR] [--manifest FILE] [--check]
  bin/zil embedded-native [--root PATH]... [--out DIR] [--manifest FILE] [--check]
  bin/zil query-plan <input.zc> [output.txt|-]
  bin/zil query-ci <input.zc> [profile|-] [output.txt|-]
  bin/zil trace <input.zc> [output.txt|-]
  bin/zil explain-query <input.zc> <query> [output.txt|-]
  bin/zil explain-authorization <input.zc> <object> <relation> <subject> [output.txt|-]
  bin/zil dependency-graph <input.zc> [output.txt|-]
  bin/zil impact <input.zc> <changed-node> [output.txt|-]
  bin/zil action-token <input.zc> <request-node> [output|-]
  bin/zil token-lifecycle <input.zc> <request-node> [output|-]
  bin/zil recovery-audit <input.zc> <request-node> [output|-]
  bin/zil agent-context <input.zc> <task-id> <agent-id> <scope> <changed-nodes> [queries|-] [targets|-] [output|-]
  bin/zil proof-obligations <input.zc> [tool|-] [output|-]
  bin/zil theorem-audit <input.zc> [output|-]
  bin/zil formalization-plan <input.zc> [output.txt|-]
  bin/zil formalization-next <input.zc> [output.txt|-]
  bin/zil authorize <input.zc> <object> <relation> <subject> [output.txt|-]
  bin/zil revision-summary <input.zilr>
  bin/zil snapshot <input.zilr> <revision> [output.txt|-]
  bin/zil causal-check <input.zilr>
  bin/zil worker [--stdio|--once]
  bin/zil exchange <operation> <input.zc> [operation-arguments...]
  bin/zil control <operation> <input.zc> [operation-arguments...]
  bin/zil plugin list [ROOT...]
  bin/zil plugin inspect <extension.json>
  bin/zil plugin run <extension.json> <command> [arguments...] [--config FILE]
  bin/zil plugin evidence <extension.json> <request.edn> [--config FILE]

Worker exposes the allowlisted ZIL-EXCHANGE/1 JSON Lines protocol. Exchange and
control use Clojure for supervision, capability ownership, and SHA-256 transport
attestation while Lean remains authoritative for parse, compile, expand,
conformance, query, authorize, impact, and recovery-audit.

Library, macro, embedded, and conformance-suite preserve Clojure workspace and
corpus orchestration while routing native semantic work through the formal control
plane. Plugin commands use ZIL-EXTENSION/1 manifests and forbid shadowing built-in
commands or authoritative capabilities.

Action-token validates preflight evidence and token intent. Token-lifecycle replays
checkpoint binding and single-use execution with revision, expiry, lease, store,
and observed-output hash checks.

Recovery-audit verifies required postconditions and validates any recovery against
the exact rollback or compensation precommitted by the issued token.

Comma-separated name lists are used by agent-context. The canonical report bytes
may be hashed as the durable context_bundle_id for action-token issuance.

Proof-obligations accepts all, -, z3, tlaps, lean4, acl2, or manual. Native
governance audits evidence and status but does not pretend to execute external solvers.

Theorem-audit checks theorem non-vacuity, dependencies, guarantees, proof evidence,
and the external claim boundary. It does not promote graph support to kernel proof.

Macro extension commands compose sorted non-recursive lib/*.zc files before the
model. Without --lib, the nearest ancestor lib/ directory is discovered.

Legacy integrations remain available explicitly:
  bin/zil --legacy <legacy-command> [arguments]
  bin/zil-legacy <legacy-command> [arguments]

Set ZIL_LEGACY_MODE=allow to temporarily route unknown commands to the legacy CLI.
EOF
}

run_native() {
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for the native CLI" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec lake exe zil -- "$@"
}

run_worker() {
  shift
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for the native exchange worker" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec lake exe zilWorker -- "$@"
}

run_exchange() {
  shift
  if ! command -v clojure >/dev/null 2>&1; then
    echo "[zil] clojure is required for exchange supervision and transport attestation" >&2
    exit 2
  fi
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for the Lean exchange worker" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec clojure -M:exchange "$@"
}

run_control() {
  shift
  if ! command -v clojure >/dev/null 2>&1; then
    echo "[zil] clojure is required for the formal control plane" >&2
    exit 2
  fi
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for Lean-authoritative control-plane operations" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec clojure -M:control "$@"
}

run_plugins() {
  shift
  if ! command -v clojure >/dev/null 2>&1; then
    echo "[zil] clojure is required for extension discovery and execution" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec clojure -M:plugins "$@"
}

run_hybrid_alias() {
  local alias_name="$1"
  shift
  if ! command -v clojure >/dev/null 2>&1; then
    echo "[zil] clojure is required for operational orchestration" >&2
    exit 2
  fi
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for Lean-authoritative semantic operations" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec clojure "-M:$alias_name" "$@"
}

run_action_token() {
  shift
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for native action-token issuance" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec lake exe zilActionToken -- "$@"
}

run_token_lifecycle() {
  shift
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for native token lifecycle auditing" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec lake exe zilTokenLifecycle -- "$@"
}

run_recovery_audit() {
  shift
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for native recovery auditing" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec lake exe zilRecoveryAudit -- "$@"
}

run_agent_context() {
  shift
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for native agent context generation" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec lake exe zilAgentContext -- "$@"
}

run_proof_obligations() {
  shift
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for native proof obligation governance" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec lake exe zilProofObligations -- "$@"
}

run_theorem_audit() {
  shift
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for native theorem auditing" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec lake exe zilTheoremAudit -- "$@"
}

run_macro() {
  local mode="$1"
  shift
  if ! command -v clojure >/dev/null 2>&1; then
    echo "[zil] clojure is required for lib/*.zc discovery and parity reporting" >&2
    exit 2
  fi
  if ! command -v lake >/dev/null 2>&1; then
    echo "[zil] lake is required for native macro compilation" >&2
    exit 2
  fi
  cd "$ZIL_ROOT"
  exec clojure -M:macro-native "$mode" "$@"
}

command_name="${1:-}"

case "$command_name" in
  compile|expand|conformance|query-plan|query-ci|trace|explain-query|explain-authorization|dependency-graph|impact|formalization-plan|formalization-next|authorize|revision-summary|snapshot|causal-check)
    run_native "$@"
    ;;
  worker)
    run_worker "$@"
    ;;
  exchange)
    run_exchange "$@"
    ;;
  control)
    run_control "$@"
    ;;
  plugin)
    run_plugins "$@"
    ;;
  library)
    shift
    run_hybrid_alias library "$@"
    ;;
  conformance-suite)
    shift
    run_hybrid_alias conformance "$@"
    ;;
  embedded-native)
    shift
    run_hybrid_alias embedded-native "$@"
    ;;
  action-token)
    run_action_token "$@"
    ;;
  token-lifecycle)
    run_token_lifecycle "$@"
    ;;
  recovery-audit)
    run_recovery_audit "$@"
    ;;
  agent-context)
    run_agent_context "$@"
    ;;
  proof-obligations)
    run_proof_obligations "$@"
    ;;
  theorem-audit)
    run_theorem_audit "$@"
    ;;
  macro-compile)
    shift
    run_macro compile "$@"
    ;;
  macro-expand)
    shift
    run_macro expand "$@"
    ;;
  macro-parity)
    shift
    run_macro parity "$@"
    ;;
  --legacy)
    shift
    exec "$SCRIPT_DIR/zil-legacy" "$@"
    ;;
  --help|-h)
    native_help
    exit 0
    ;;
  "")
    native_help >&2
    exit 2
    ;;
  *)
    if [[ "${ZIL_LEGACY_MODE:-deny}" == "allow" ]]; then
      exec "$SCRIPT_DIR/zil-legacy" "$@"
    fi
    cat >&2 <<EOF
[zil] '$command_name' is not a native or registered control-plane command.

Use one of:
  bin/zil --legacy $*
  bin/zil-legacy $*

For a source file, use:
  bin/zil compile <input.zc>
EOF
    exit 2
    ;;
esac
