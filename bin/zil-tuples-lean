#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ZIL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ZIL_JAR="${ZIL_JAR:-$ZIL_ROOT/dist/zil-standalone.jar}"

if command -v java >/dev/null 2>&1 && [[ -f "$ZIL_JAR" ]]; then
  exec java -cp "$ZIL_JAR" clojure.main -m zil.bridge.tuple-lean "$@"
fi

if command -v clojure >/dev/null 2>&1; then
  cd "$ZIL_ROOT"
  exec clojure -M -m zil.bridge.tuple-lean "$@"
fi

cat >&2 <<EOF
[zil-tuples-lean] no runtime found.

Expected one of:
  1) Java + built jar at: $ZIL_JAR
  2) clojure CLI in PATH
EOF
exit 2
